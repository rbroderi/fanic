# FANIC non-secret runtime configuration
# Copy to: /etc/fanic/fanic.env

FANIC_ENVIRONMENT=production
FANIC_ENABLE_BEARTYPE=1
FANIC_DATA_DIR=/mnt/storage
FANIC_DB_PATH=/opt/fanic/runtime/fanic.db
FANIC_LOG_PATH_TEMPLATE=/var/log/fanic/%TIMESTAMP%.log

FANIC_AUTH0_ENABLED=true
FANIC_AUTH0_CALLBACK_URL=https://fanic.media/account/callback
FANIC_AUTH0_LOGOUT_RETURN_URL=https://fanic.media/
FANIC_AUTH0_SUPERADMIN_EMAIL=admin@fanic.media

# Secret values should be provided through file paths, not plaintext values.
FANIC_SESSION_SECRET_FILE=/etc/fanic/credentials/session_secret
FANIC_ADMIN_PASSWORD_HASH_FILE=/etc/fanic/credentials/admin_password_hash
FANIC_AUTH0_DOMAIN_FILE=/etc/fanic/credentials/auth0_domain
FANIC_AUTH0_CLIENT_ID_FILE=/etc/fanic/credentials/auth0_client_id
FANIC_AUTH0_CLIENT_SECRET_FILE=/etc/fanic/credentials/auth0_client_secret
FANIC_ALPHA_INVITE_CODES_CSV_FILE=/etc/fanic/credentials/alpha_invite_codes_csv
